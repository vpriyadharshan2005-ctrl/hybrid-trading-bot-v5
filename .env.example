# ══════════════════════════════════════════════════════════════
# HYBRID TRADING BOT v5.0 — ENVIRONMENT CONFIGURATION TEMPLATE
# ══════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Copy this file → rename to .env
#   2. Fill in your real values
#   3. NEVER upload .env to GitHub (only this .env.example)
#   4. On Render → add these as Environment Variables
# ══════════════════════════════════════════════════════════════

# ── TELEGRAM ──────────────────────────────────────────────────
# Get TOKEN from @BotFather on Telegram
# Get CHAT_ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# ── FINNHUB API (Forex + Gold + Silver) ───────────────────────
# Free API key at: https://finnhub.io → Sign Up → Dashboard
# Covers: EURUSD, GBPUSD, USDJPY, AUDUSD, XAUUSD, XAGUSD
FINNHUB_API_KEY=your_finnhub_api_key_here

# ── DHAN API (India NSE Indices) ──────────────────────────────
# Get from: https://developer.dhanhq.co → Sandbox → Generate Token
# Covers: NIFTY, BANKNIFTY, FINNIFTY
DHAN_CLIENT_ID=your_dhan_client_id_here
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# ── DELTA EXCHANGE (Crypto) ───────────────────────────────────
# NO API KEY NEEDED — Public market data API
# Covers: BTCUSDT, ETHUSDT, XRPUSDT, LTCUSDT, BNBUSDT
# Nothing to fill here ✅

# ── METATRADER (Optional Fallback) ────────────────────────────
# Only needed if you use MetaTrader EA as fallback data source
# After Render deploy, update this to your Render URL
METATRADER_WEBHOOK=https://your-bot-name.onrender.com/api/metatrader/receive

# ── BOT CONFIGURATION ─────────────────────────────────────────
PORT=5000
NODE_ENV=production
